<Window x:Class="DiceGame1.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Игра — Кубики" Height="680" Width="980" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnMenu" Content="← Меню" Click="BtnMenu_Click" Width="90"/>
                <Button x:Name="BtnNewGame" Content="Новая игра" Click="BtnNewGame_Click" Width="120" Margin="8,0,0,0"/>
                <Button x:Name="BtnEnd" Content="Закончить игру" Click="BtnEnd_Click" Width="120" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Text="Создание прототипа" FontWeight="Bold" Margin="0,8,0,4"/>
            <TextBlock Text="Имя прототипа:"/>
            <TextBox x:Name="TxtProtoName" Width="340"/>
            <TextBlock Text="Грани (ровно 6 чисел 1..6, через запятую):" Margin="0,6,0,0"/>
            <TextBox x:Name="TxtFaces" Width="340" Height="60" Text="1,2,3,4,5,6"/>

            <Button x:Name="BtnCreateProto" Content="Создать прототип и начать" Click="BtnCreateProto_Click" Width="260" Margin="0,8,0,0"/>

            <Separator Margin="0,12,0,12"/>
            <TextBlock Text="Раунд / Цель" FontWeight="Bold"/>
            <TextBlock x:Name="TxtRound" FontSize="14" Margin="0,6,0,0">Раунд: -</TextBlock>
            <TextBlock x:Name="TxtTarget" FontSize="14">Цель: -</TextBlock>

            <TextBlock Text="Выберите модификатор для следующих клонов" FontWeight="Bold" Margin="0,8,0,4"/>
            <ComboBox x:Name="CmbMods" Width="340" SelectionChanged="CmbMods_SelectionChanged" Visibility="Collapsed"/>
            <TextBlock x:Name="TxtModDescription" Text="Описание модификатора" TextWrapping="Wrap" Height="60" Margin="0,6,0,0" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button x:Name="BtnCreateClones" Content="Создать клоны для следующего раунда" Click="BtnCreateClones_Click" Width="260" Visibility="Collapsed"/>
                <Button x:Name="BtnRollAll" Content="Бросить все" Click="BtnRollAll_Click" Width="90" Margin="8,0,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <Separator Margin="0,12,0,12"/>
            <TextBlock Text="Очки" FontWeight="Bold"/>
            <TextBlock x:Name="TxtScore" FontSize="14">Очки: 0</TextBlock>
            <TextBlock x:Name="TxtBest" FontSize="14">Лучший: 0</TextBlock>

            <TextBlock Text="Последние события" FontWeight="Bold" Margin="0,10,0,4"/>
            <TextBlock x:Name="TxtLog" Text="—" TextWrapping="Wrap" Height="90"/>
        </StackPanel>

        <StackPanel Grid.Column="2">
            <TextBlock Text="Поле кубиков" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="520">
                <WrapPanel x:Name="DicePanel" />
            </ScrollViewer>

            <Separator Margin="0,10,0,10"/>
            <TextBlock Text="Результат последнего раунда" FontWeight="Bold"/>
            <TextBlock x:Name="TxtRoundResult" Height="80" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>